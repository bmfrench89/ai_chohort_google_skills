# Credentials — never commit these
*.json.key
*-key.json
service-account*.json
gcp-credentials*.json
.env
.env.*
*.pem

# Go build output
sample-app/server
sample-app/app
*.exe

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local kube config copies
kubeconfig
*.kubeconfig

# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log
# tfvars may hold project-specific/sensitive values; commit *.tfvars.example instead
*.tfvars
!*.tfvars.example
override.tf
override.tf.json
*_override.tf
*_override.tf.json
